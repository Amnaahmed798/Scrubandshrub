# Google Maps API Key
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Backend API URL (CRITICAL - Update for your environment)
# For Vercel deployment, use full backend URL:
# NEXT_PUBLIC_BACKEND_URL="http://scrubshrub.com:8000/api/v1"
# NEXT_PUBLIC_API_URL="http://scrubshrub.com:8000/api/v1"
# NEXT_PUBLIC_API_BASE_URL="http://scrubshrub.com:8000"

# For local development:
# NEXT_PUBLIC_BACKEND_URL="http://localhost:8000/api/v1"
# NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"
# NEXT_PUBLIC_API_BASE_URL="http://localhost:8000"

NEXT_PUBLIC_APP_ENV=production

# STC Pay Configuration
NEXT_PUBLIC_STC_PAY_MERCHANT_ID="your_stc_pay_merchant_id"
NEXT_PUBLIC_STC_PAY_API_KEY="your_stc_pay_api_key"
NEXT_PUBLIC_STC_PAY_CALLBACK_URL="https://yourdomain.com/api/stcpay/callback"
NEXT_PUBLIC_STC_PAY_ENVIRONMENT="production"
