# Google Maps API Key
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Backend API URL (CRITICAL - Updated for Vercel deployment)
# Backend is running at http://scrubshrub.com:8000
NEXT_PUBLIC_BACKEND_URL="http://scrubshrub.com:8000/api/v1"
