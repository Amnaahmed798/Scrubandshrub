                          mappedDescription = 'Thorough cleaning of bathroom including toilet, shower, tub, sink, mirrors, and tile surfaces. Our process includes scrubbing tiles, sanitizing fixtures, removing soap scum, cleaning mirrors, and disinfecting all surfaces. We use bathroom-safe products to prevent damage to surfaces while ensuring complete sanitization.';
                          mappedIcon = 'Shield';
