                              mappedIcon = 'Vacuum';
                            } else {
                              mappedName = 'Interior Detail';
                              mappedDescription = 'Comprehensive interior detailing including deep cleaning of seats, carpets, and upholstery, conditioning of leather surfaces, cleaning of air vents, sanitization of high-touch areas, and complete interior refresh. This service restores your car\'s interior to showroom condition.';
                              mappedIcon = 'Tachometer';
                            }
                            interiorCount++;
                          }
                        } else if ((headCat.name.toLowerCase().includes('exterior') || headCat.slug?.toLowerCase().includes('exterior')) ||
                                  (subCat.name.toLowerCase().includes('exterior') || subCat.name.toLowerCase().includes('wash'))) {
                          // Map exterior services based on keywords in the name
                          if (subCat.name.toLowerCase().includes('basic wash') || subCat.name.toLowerCase().includes('basic') && subCat.name.toLowerCase().includes('wash')) {
                            mappedName = 'Exterior Basic Wash';
                            mappedDescription = 'Basic exterior wash including soap wash, rinse, and hand dry. Our service removes surface dirt, dust, and grime to keep your vehicle looking clean and well-maintained. Includes cleaning of wheels and tires.';
                            mappedIcon = 'Soap';
                            exteriorCount++;
                          } else if (subCat.name.toLowerCase().includes('premium wash') || subCat.name.toLowerCase().includes('wax & polish') || subCat.name.toLowerCase().includes('wax')) {
                            mappedName = 'Wax & Polish';
                            mappedDescription = 'Professional waxing and polishing service that protects your car\'s paint while providing a deep shine. Our service includes paint cleaning, polishing to remove light scratches, and application of protective wax to maintain your vehicle\'s appearance and protect against environmental damage.';
