                            exteriorCount++;
                          } else if (subCat.name.toLowerCase().includes('full detail') || subCat.name.toLowerCase().includes('detail') && !subCat.name.toLowerCase().includes('interior')) {
                            mappedName = 'Full Exterior Detail';
                            mappedDescription = 'Complete exterior detailing including clay bar treatment to remove contaminants, paint correction for swirl marks and scratches, multiple-stage waxing, and comprehensive cleaning of all exterior surfaces. This premium service restores your vehicle\'s paint to like-new condition.';
                            mappedIcon = 'Tint';
                            exteriorCount++;
                          } else {
                            // Fallback for exterior services based on count
                            if (exteriorCount === 0) {
                              mappedName = 'Exterior Basic Wash';
                              mappedDescription = 'Basic exterior wash including soap wash, rinse, and hand dry. Our service removes surface dirt, dust, and grime to keep your vehicle looking clean and well-maintained. Includes cleaning of wheels and tires.';
                              mappedIcon = 'Soap';
                            } else if (exteriorCount === 1) {
                              mappedName = 'Wax & Polish';
                              mappedDescription = 'Professional waxing and polishing service that protects your car\'s paint while providing a deep shine. Our service includes paint cleaning, polishing to remove light scratches, and application of protective wax to maintain your vehicle\'s appearance and protect against environmental damage.';
                              mappedIcon = 'Water';
                            } else {
                              mappedName = 'Full Exterior Detail';
                              mappedDescription = 'Complete exterior detailing including clay bar treatment to remove contaminants, paint correction for swirl marks and scratches, multiple-stage waxing, and comprehensive cleaning of all exterior surfaces. This premium service restores your vehicle\'s paint to like-new condition.';
                              mappedIcon = 'Tint';
                            }
                            exteriorCount++;
                          }
                        } else {
                          // If category isn't clearly identified, try to infer from service name
                          if (subCat.name.toLowerCase().includes('interior')) {
                            if (subCat.name.toLowerCase().includes('basic interior') || subCat.name.toLowerCase().includes('basic') && subCat.name.toLowerCase().includes('interior')) {
                              mappedName = 'Interior Basic Clean';
                              mappedDescription = 'Basic interior cleaning including vacuuming seats and carpets, wiping down dashboard and surfaces, cleaning windows, and removing surface debris. Perfect for regular maintenance between deep cleans.';
                              mappedIcon = 'Chair';
                              interiorCount++;
                            } else if (subCat.name.toLowerCase().includes('premium interior') || subCat.name.toLowerCase().includes('interior vacuum')) {
                              mappedName = 'Interior Vacuum';
                              mappedDescription = 'Thorough vacuuming of seats, carpets, floor mats, and hard-to-reach areas using professional-grade equipment. Our service removes embedded dirt, dust, and debris to keep your car interior fresh and clean.';
                              mappedIcon = 'Vacuum';
                              interiorCount++;
                            } else if (subCat.name.toLowerCase().includes('full interior detail') || subCat.name.toLowerCase().includes('interior detail')) {
                              mappedName = 'Interior Detail';
                              mappedDescription = 'Comprehensive interior detailing including deep cleaning of seats, carpets, and upholstery, conditioning of leather surfaces, cleaning of air vents, sanitization of high-touch areas, and complete interior refresh. This service restores your car\'s interior to showroom condition.';
                              mappedIcon = 'Tachometer';
                              interiorCount++;
                            } else {
                              // Fallback for interior services based on count
                              if (interiorCount === 0) {
                                mappedName = 'Interior Basic Clean';
                                mappedDescription = 'Basic interior cleaning including vacuuming seats and carpets, wiping down dashboard and surfaces, cleaning windows, and removing surface debris. Perfect for regular maintenance between deep cleans.';
                                mappedIcon = 'Chair';
                              } else if (interiorCount === 1) {
                                mappedName = 'Interior Vacuum';
                                mappedDescription = 'Thorough vacuuming of seats, carpets, floor mats, and hard-to-reach areas using professional-grade equipment. Our service removes embedded dirt, dust, and debris to keep your car interior fresh and clean.';
                                mappedIcon = 'Vacuum';
                              } else {
                                mappedName = 'Interior Detail';
                                mappedDescription = 'Comprehensive interior detailing including deep cleaning of seats, carpets, and upholstery, conditioning of leather surfaces, cleaning of air vents, sanitization of high-touch areas, and complete interior refresh. This service restores your car\'s interior to showroom condition.';
                                mappedIcon = 'Tachometer';
                              }
                              interiorCount++;
                            }
                          } else if (subCat.name.toLowerCase().includes('exterior') || subCat.name.toLowerCase().includes('wash')) {
                            if (subCat.name.toLowerCase().includes('basic wash') || subCat.name.toLowerCase().includes('basic') && subCat.name.toLowerCase().includes('wash')) {
                              mappedName = 'Exterior Basic Wash';
                              mappedDescription = 'Basic exterior wash including soap wash, rinse, and hand dry. Our service removes surface dirt, dust, and grime to keep your vehicle looking clean and well-maintained. Includes cleaning of wheels and tires.';
                              mappedIcon = 'Soap';
                              exteriorCount++;
                            } else if (subCat.name.toLowerCase().includes('premium wash') || subCat.name.toLowerCase().includes('wax & polish') || subCat.name.toLowerCase().includes('wax')) {
                              mappedName = 'Wax & Polish';
                              mappedDescription = 'Professional waxing and polishing service that protects your car\'s paint while providing a deep shine. Our service includes paint cleaning, polishing to remove light scratches, and application of protective wax to maintain your vehicle\'s appearance and protect against environmental damage.';
                              mappedIcon = 'Water';
                              exteriorCount++;
                            } else if (subCat.name.toLowerCase().includes('full detail') || subCat.name.toLowerCase().includes('detail') && !subCat.name.toLowerCase().includes('interior')) {
                              mappedName = 'Full Exterior Detail';
                              mappedDescription = 'Complete exterior detailing including clay bar treatment to remove contaminants, paint correction for swirl marks and scratches, multiple-stage waxing, and comprehensive cleaning of all exterior surfaces. This premium service restores your vehicle\'s paint to like-new condition.';
                              mappedIcon = 'Tint';
                              exteriorCount++;
                            } else {
                              // Fallback for exterior services based on count
                              if (exteriorCount === 0) {
                                mappedName = 'Exterior Basic Wash';
                                mappedDescription = 'Basic exterior wash including soap wash, rinse, and hand dry. Our service removes surface dirt, dust, and grime to keep your vehicle looking clean and well-maintained. Includes cleaning of wheels and tires.';
                                mappedIcon = 'Soap';
                              } else if (exteriorCount === 1) {
                                mappedName = 'Wax & Polish';
                                mappedDescription = 'Professional waxing and polishing service that protects your car\'s paint while providing a deep shine. Our service includes paint cleaning, polishing to remove light scratches, and application of protective wax to maintain your vehicle\'s appearance and protect against environmental damage.';
                                mappedIcon = 'Water';
                              } else {
                                mappedName = 'Full Exterior Detail';
                                mappedDescription = 'Complete exterior detailing including clay bar treatment to remove contaminants, paint correction for swirl marks and scratches, multiple-stage waxing, and comprehensive cleaning of all exterior surfaces. This premium service restores your vehicle\'s paint to like-new condition.';
                                mappedIcon = 'Tint';
                              }
                              exteriorCount++;
                            }
                          } else {
                            // If no clear indication from name, use position-based assignment
                            if (interiorCount < 3) {
                              if (interiorCount === 0) {
                                mappedName = 'Interior Basic Clean';
