          updated_at: new Date().toISOString(),
          isSelected: false
        },
        {
          id: `${serviceSlug}-deluxe`,
          name: 'Deluxe Service',
          slug: 'deluxe',
          description: 'Top-tier service option',
          detailedDescription: 'Our deluxe service represents the highest level of service we offer. Includes comprehensive treatment, premium products, extended service time, and meticulous attention to every detail. Perfect for special occasions or when you want the absolute best care for your vehicle or space.',
          category: 'deluxe',
          icon: 'Home',
          is_active: true,
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
          isSelected: false
        }
      ];

      category2Services = [];
      category1Title = 'Service Options';
      category2Title = '';
    }
  }
}
} // This closes the main if statement that starts at line 1481
// Now comes the main return statement for the component
return (
    <div className="min-h-screen bg-white">
      <div className="max-w-4xl mx-auto px-4 py-6">
        <div className="flex items-center mb-6">
          {getServiceImage(serviceSlug)}
          <div className="ml-4">
            <h1 className="text-2xl font-bold text-gray-900">Customize {serviceDetails?.name || serviceSlug.replace('-', ' ')}</h1>
            <p className="text-gray-600">{serviceDetails?.description || 'Select options for your service'}</p>
          </div>
        </div>

        {/* Vehicle Type Selection - Only show for car washing */}
        {serviceSlug === 'car-washing' && (
          <div className="mb-6">
            <div className="p-4 border rounded-lg">
              <h3 className="font-medium text-gray-900 mb-2">Select Vehicle Type</h3>
              <div className="flex space-x-4">
                {(['sedan', 'suv', 'hatchback', 'bike'] as const).map((type) => (
                  <button
                    key={type}
                    className={`px-4 py-2 rounded-md ${
                      selectedVehicleType === type
                        ? 'bg-teal-600 text-white'
                        : 'bg-gray-200 text-gray-700 hover:bg-gray-300'
                    }`}
                    onClick={() => handleVehicleTypeChange(type)}
                  >
                    {type.charAt(0).toUpperCase() + type.slice(1)}
