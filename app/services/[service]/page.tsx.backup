        // First try to fetch the specific service's subcategories from the API as a secondary fallback
        let apiServices: any[] = [];

        try {
          const hierarchyResponse = await fetch(`${process.env.NEXT_PUBLIC_API_BASE_URL || 'http://localhost:8000'}/api/v1/services/hierarchy`);
          if (hierarchyResponse.ok) {
            const hierarchyData = await hierarchyResponse.json();

            if (hierarchyData.data && Array.isArray(hierarchyData.data)) {
              // Find the main service in the hierarchy
              const mainService = hierarchyData.data.find((s: any) => s.slug === serviceSlug);

              if (mainService && mainService.head_categories && mainService.head_categories.length > 0) {

                // For consistency with mock data structure, we'll map API services to exact mock data names
                // Count services per category to assign proper names
                let interiorCount = 0;
                let exteriorCount = 0;
                let deepCleaningCount = 0;
                let maintenanceCount = 0;
                let kitchenCount = 0;
                let bathroomCount = 0;
                let floorCount = 0;
                let windowCount = 0;
                let dustingCount = 0;
                let organizingCount = 0;
                let sanitizationCount = 0;
                let detailingCount = 0;
                let landscapingCount = 0;
                let lawnCount = 0;
                let otherCount = 0;

                for (const headCat of mainService.head_categories) {
                  if (headCat.sub_categories && headCat.sub_categories.length > 0) {
                    for (const subCat of headCat.sub_categories) {

                      // Determine the appropriate name based on service type and category
