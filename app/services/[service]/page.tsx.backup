                      let mappedDescription = subCat.description;
                      let mappedIcon = subCat.icon || 'Broom';

                      if (serviceSlug === 'car-washing') {
                        // Use exact names from mock data for car washing
                        // Handle the specific names that might come from the API
                        if ((headCat.name.toLowerCase().includes('interior') || headCat.slug?.toLowerCase().includes('interior')) ||
                            (subCat.name.toLowerCase().includes('interior'))) {
                          // Map interior services based on keywords in the name
                          if (subCat.name.toLowerCase().includes('basic interior') || subCat.name.toLowerCase().includes('basic') && subCat.name.toLowerCase().includes('interior')) {
                            mappedName = 'Interior Basic Clean';
                            mappedDescription = 'Basic interior cleaning including vacuuming seats and carpets, wiping down dashboard and surfaces, cleaning windows, and removing surface debris. Perfect for regular maintenance between deep cleans.';
                            mappedIcon = 'Chair';
                            interiorCount++;
                          } else if (subCat.name.toLowerCase().includes('premium interior') || subCat.name.toLowerCase().includes('interior vacuum')) {
                            mappedName = 'Interior Vacuum';
                            mappedDescription = 'Thorough vacuuming of seats, carpets, floor mats, and hard-to-reach areas using professional-grade equipment. Our service removes embedded dirt, dust, and debris to keep your car interior fresh and clean.';
                            mappedIcon = 'Vacuum';
                            interiorCount++;
                          } else if (subCat.name.toLowerCase().includes('full interior detail') || subCat.name.toLowerCase().includes('interior detail')) {
                            mappedName = 'Interior Detail';
                            mappedDescription = 'Comprehensive interior detailing including deep cleaning of seats, carpets, and upholstery, conditioning of leather surfaces, cleaning of air vents, sanitization of high-touch areas, and complete interior refresh. This service restores your car\'s interior to showroom condition.';
                            mappedIcon = 'Tachometer';
                            interiorCount++;
                          } else {
                            // Fallback for interior services based on count
                            if (interiorCount === 0) {
                              mappedName = 'Interior Basic Clean';
                              mappedDescription = 'Basic interior cleaning including vacuuming seats and carpets, wiping down dashboard and surfaces, cleaning windows, and removing surface debris. Perfect for regular maintenance between deep cleans.';
                              mappedIcon = 'Chair';
                            } else if (interiorCount === 1) {
                              mappedName = 'Interior Vacuum';
