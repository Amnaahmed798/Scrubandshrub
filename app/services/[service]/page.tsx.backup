'use client';

import React, { useState, useEffect } from 'react';
import { Service as ServiceType } from '@/lib/types';
import { getPricing } from '@/lib/services/pricing-service';
import { calculateSubtotal } from '@/lib/utils';
import { ServiceCard } from '@/components/service/service-card';
import { PricingDisplay } from '@/components/pricing/pricing-display';
import { VehicleSelector } from '@/components/vehicle/vehicle-selector';
import { FaHome, FaLeaf, FaTint, FaBroom, FaCar, FaWrench, FaMagic, FaSoap, FaShower, FaChair, FaCouch, FaTachometerAlt, FaSnowflake, FaShieldAlt, FaCarSide, FaWater, FaTools } from 'react-icons/fa';

interface ServicePageProps {
  params: {
    service: string;
  };
}

const ServiceDetailPage: React.FC<ServicePageProps> = ({ params }) => {
  const [services, setServices] = useState<ServiceType[]>([]);
  const [loading, setLoading] = useState<boolean>(true);
  const [error, setError] = useState<string | null>(null);
  const [subtotal, setSubtotal] = useState<number>(0);
  const [selectedVehicleType, setSelectedVehicleType] = useState<'sedan' | 'suv' | 'hatchback' | 'bike'>('sedan');
  const [serviceDetails, setServiceDetails] = useState<any>(null);

  const serviceSlug = params.service;

  // Fetch service details and related data
  useEffect(() => {
    const fetchServiceData = async () => {
      try {
        setLoading(true);
        setError(null);

        // First, try to fetch services from the API using the hierarchy endpoint
        try {
          const response = await fetch(`${process.env.NEXT_PUBLIC_API_BASE_URL || 'http://localhost:8000'}/api/v1/services/hierarchy`);
          if (response.ok) {
            const data = await response.json();
            const allServices = data.data;

            // Find the main service based on the slug
            const mainService = allServices.find((s: any) => s.slug === serviceSlug);

            if (mainService) {
              // Set service details from API
              setServiceDetails({
                name: mainService.name,
                description: mainService.description,
                slug: serviceSlug
              });

              // Use head categories and their sub-categories from the hierarchy data
              let allSubCategories = [];

              // Check if the main service has head categories with subcategories
              if (mainService.head_categories && Array.isArray(mainService.head_categories)) {
                for (const headCat of mainService.head_categories) {
                  if (headCat.sub_categories && Array.isArray(headCat.sub_categories)) {
                    for (const subCat of headCat.sub_categories) {
                      allSubCategories.push(subCat);
                    }
                  }
                }
              }

              // Fallback to sub_services if head_categories structure isn't available
              if (allSubCategories.length === 0 && mainService.sub_services && Array.isArray(mainService.sub_services)) {
                for (const subService of mainService.sub_services) {
                  if (subService.sub_categories && Array.isArray(subService.sub_categories)) {
                    for (const subCat of subService.sub_categories) {
                      allSubCategories.push(subCat);
                    }
                  }
                }
              }

              // Fetch pricing data to enhance services with price information
              let pricingData: any[] = [];
              try {
                const pricingResponse = await fetch(`${process.env.NEXT_PUBLIC_API_BASE_URL || 'http://localhost:8000'}/api/v1/pricing?vehicle_type=${selectedVehicleType}`);
                if (pricingResponse.ok) {
                  const pricingResult = await pricingResponse.json();
                  if (pricingResult.status === 'success' && Array.isArray(pricingResult.data)) {
                    pricingData = pricingResult.data;
                  }
                }
              } catch (pricingError) {
                console.warn('Failed to fetch pricing data, services will not have price information:', pricingError);
              }

              // Map API services to the format expected by the UI with name mapping for all service types
              const mappedServices = allSubCategories.map((service: any) => {
                // Apply name mapping based on service type
                let mappedName = service.name;

                if (serviceSlug === 'car-washing') {
                  // Map API service slugs to meaningful names for car washing
                  const serviceSlugMap: Record<string, string> = {
                    'interior-basic': 'Interior Basic Clean',
                    'interior-vacuum': 'Interior Vacuum',
                    'interior-detail': 'Interior Detail',
                    'exterior-basic': 'Exterior Basic Wash',
                    'exterior-wax': 'Wax & Polish',
                    'exterior-detail': 'Full Exterior Detail'
                  };

                  mappedName = serviceSlugMap[service.slug] || service.name;
                } else if (serviceSlug === 'house-cleaning') {
                  // Map API service slugs to meaningful names for house cleaning
                  const serviceSlugMap: Record<string, string> = {
                    'deep-kitchen': 'Kitchen Deep Clean',
                    'deep-bathroom': 'Bathroom Deep Clean',
                    'deep-floor': 'Floor Cleaning',
                    'maintenance-windows': 'Window Cleaning',
                    'maintenance-dusting': 'Dusting Service',
                    'maintenance-organizing': 'Organizing Service'
                  };

                  mappedName = serviceSlugMap[service.slug] || service.name;
                } else if (serviceSlug === 'deep-cleaning') {
                  // Map API service slugs to meaningful names for deep cleaning
                  const serviceSlugMap: Record<string, string> = {
                    'sanitization-basic': 'Basic Sanitization',
                    'sanitization-disinfection': 'Disinfection Service',
                    'sanitization-ozone': 'Ozone Treatment',
                    'detailing-scrub': 'Scrubbing Detail',
                    'detailing-polish': 'Polishing Service',
                    'detailing-steam': 'Steam Cleaning'
                  };

                  mappedName = serviceSlugMap[service.slug] || service.name;
                } else if (serviceSlug === 'gardening') {
                  // Map API service slugs to meaningful names for gardening
                  const serviceSlugMap: Record<string, string> = {
                    'landscaping-pruning': 'Pruning Service',
                    'landscaping-planting': 'Planting Service',
                    'landscaping-trimming': 'Lawn Trimming',
                    'maintenance-mowing': 'Lawn Mowing',
                    'maintenance-weeding': 'Weeding Service',
                    'maintenance-fertilizing': 'Fertilizing Service'
                  };

                  mappedName = serviceSlugMap[service.slug] || service.name;
                } else if (serviceSlug === 'window-cleaning') {
                  // Map API service slugs to meaningful names for window cleaning
                  const serviceSlugMap: Record<string, string> = {
                    'exterior-standard': 'Exterior Window Clean',
                    'exterior-pressure': 'Exterior Pressure Clean',
                    'exterior-stain': 'Exterior Stain Removal',
                    'interior-standard': 'Interior Window Clean',
                    'interior-stain': 'Interior Stain Removal',
                    'interior-polish': 'Interior Polish'
                  };

                  mappedName = serviceSlugMap[service.slug] || service.name;
                } else if (serviceSlug === 'waterless-wash') {
                  // Map API service slugs to meaningful names for waterless wash
                  const serviceSlugMap: Record<string, string> = {
                    'basic': 'Basic Service',
                    'premium': 'Premium Service',
                    'deluxe': 'Deluxe Service'
                  };

                  mappedName = serviceSlugMap[service.slug] || service.name;
                }

                // Find pricing for this service
                const servicePricing = pricingData.find((pricingItem: any) =>
                  pricingItem.serviceId === service.id.toString()
                );

                const price = servicePricing?.price || 0; // Default to 0 if no pricing found

                return {
                  id: service.id.toString(), // Convert to string to match expected format
                  name: mappedName,
                  slug: service.slug,
                  description: service.description,
                  detailedDescription: service.detailed_description || service.description, // Use detailed description if available
                  category: service.category,
                  icon: service.icon || 'Broom', // Default icon
                  is_active: service.is_active,
                  created_at: service.created_at,
                  updated_at: service.updated_at,
                  isSelected: false,
                  price: price // Add price from pricing API
                };
              });

              setServices(mappedServices as ServiceType[]);
              setLoading(false);
              return;
            }
          }
        } catch (apiError) {
          console.warn('Failed to fetch services from API, falling back to mock data:', apiError);
        }

        // Fallback to mock data if API call fails
        const serviceTitles: Record<string, string> = {
          'car-washing': 'Car Washing',
          'deep-cleaning': 'Deep Cleaning',
          'gardening': 'Gardening',
          'house-cleaning': 'House Cleaning',
          'window-cleaning': 'Window Cleaning',
          'waterless-wash': 'Waterless Wash'
        };

        const serviceDescriptions: Record<string, string> = {
          'car-washing': 'Professional car washing and detailing services',
          'deep-cleaning': 'Thorough deep cleaning for homes and offices',
          'gardening': 'Lawn care and garden maintenance services',
          'house-cleaning': 'Regular house cleaning and maintenance',
          'window-cleaning': 'Professional window and glass cleaning',
          'waterless-wash': 'Eco-friendly cleaning without water'
        };

        setServiceDetails({
          name: serviceTitles[serviceSlug] || 'Service',
          description: serviceDescriptions[serviceSlug] || 'Service details',
          slug: serviceSlug
