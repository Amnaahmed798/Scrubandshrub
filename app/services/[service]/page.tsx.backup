        setServices(mockServices as ServiceType[]);
      } catch (err) {
        setError('Failed to load service details. Please try again.');
        console.error('Error fetching service data:', err);
      } finally {
        setLoading(false);
      }
    };

    if (serviceSlug) {
      fetchServiceData();
    }
  }, [serviceSlug]);

  // Recalculate subtotal when services selection changes
  useEffect(() => {
    const calculateSubtotal = () => {
      const selectedServices = services.filter(service => service.isSelected);

      // If no services selected, set subtotal to 0
      if (selectedServices.length === 0) {
        setSubtotal(0);
        return;
      }

      // Calculate total using the price property already attached to services
      const total = selectedServices.reduce((sum, service) => sum + (service.price || 0), 0);
      setSubtotal(total);
    };

    calculateSubtotal();
  }, [services]);

  const handleServiceSelection = (serviceId: string, isSelected: boolean) => {
    setServices(prevServices => {
      return [...prevServices.map(service => {
        if (service.id === serviceId) {
          return { ...service, isSelected };
        }
        return service;
      })];
    });
  };


  const handleVehicleTypeChange = (newVehicleType: 'sedan' | 'suv' | 'hatchback' | 'bike') => {
    setSelectedVehicleType(newVehicleType);
    // Refetch services when vehicle type changes to update pricing
    if (serviceSlug) {
      fetchServiceData();
    }
  };


  const getServiceImage = (serviceType: string) => {
    const serviceTypeLower = serviceType.toLowerCase();

    if (serviceTypeLower.includes('car')) return <img src="/images/service-car-wash.jpg" alt="Car Washing" className="w-16 h-16 object-cover rounded-full" onError={(e) => {(e.currentTarget as HTMLImageElement).src = "https://placehold.co/64x64/0f766e/white?text=Car";}} />;
    if (serviceTypeLower.includes('deep')) return <img src="/images/service-deep-cleaning.jpg" alt="Deep Cleaning" className="w-16 h-16 object-cover rounded-full" onError={(e) => {(e.currentTarget as HTMLImageElement).src = "https://placehold.co/64x64/0f766e/white?text=Deep";}} />;
    if (serviceTypeLower.includes('garden')) return <img src="/images/service-gardening.jpg" alt="Gardening" className="w-16 h-16 object-cover rounded-full" onError={(e) => {(e.currentTarget as HTMLImageElement).src = "https://placehold.co/64x64/0f766e/white?text=Garden";}} />;
    if (serviceTypeLower.includes('house')) return <img src="/images/service-house-cleaning.jpg" alt="House Cleaning" className="w-16 h-16 object-cover rounded-full" onError={(e) => {(e.currentTarget as HTMLImageElement).src = "https://placehold.co/64x64/0f766e/white?text=House";}} />;
    if (serviceTypeLower.includes('window')) return <img src="/images/service-window-cleaning.jpg" alt="Window Cleaning" className="w-16 h-16 object-cover rounded-full" onError={(e) => {(e.currentTarget as HTMLImageElement).src = "https://placehold.co/64x64/0f766e/white?text=Window";}} />;
    if (serviceTypeLower.includes('waterless')) return <img src="/images/service-waterless-wash.jpg" alt="Waterless Wash" className="w-16 h-16 object-cover rounded-full" onError={(e) => {(e.currentTarget as HTMLImageElement).src = "https://placehold.co/64x64/0f766e/white?text=Waterless";}} />;

    return <img src="/images/service-default.jpg" alt="Service" className="w-16 h-16 object-cover rounded-full" onError={(e) => {(e.currentTarget as HTMLImageElement).src = "https://placehold.co/64x64/0f766e/white?text=Svc";}} />;
  };

  const handleConfirmSelections = async () => {
    try {
      // Get selected service IDs
      const selectedServiceIds = services
        .filter(service => service.isSelected)
        .map(service => service.id);

      if (selectedServiceIds.length === 0) {
        alert('Please select at least one service option');
        return;
      }

      // Get selected service data to pass to booking page
      const selectedServices = services.filter(service => service.isSelected);

      // Navigate to the booking page with selected services and vehicle type in URL
      const serviceSlug = params.service;
      const encodedServices = encodeURIComponent(JSON.stringify({
        serviceSlug,
        serviceName: serviceDetails?.name || serviceSlug.replace('-', ' '),
        selectedServices,
        selectedVehicleType
      }));

      window.location.href = `/book?selectedData=${encodedServices}`; // Redirect to booking page with data
    } catch (err) {
      setError('Failed to confirm selections. Please try again.');
      console.error('Error confirming selections:', err);
    }
  };

  if (loading) {
    return (
      <div className="min-h-screen bg-white flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-teal-600 mx-auto"></div>
          <p className="mt-4 text-gray-600">Loading {serviceDetails?.name || serviceSlug.replace('-', ' ')}...</p>
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="min-h-screen bg-white flex items-center justify-center">
        <div className="text-center p-4">
          <div className="text-red-500 text-xl mb-2">⚠️</div>
          <p className="text-red-600">{error}</p>
          <button
            onClick={() => window.location.reload()}
            className="mt-4 bg-teal-600 text-white px-4 py-2 rounded-md hover:bg-teal-700"
          >
            Retry
          </button>
        </div>
      </div>
    );
  }

  // Define service categories based on the service type
  let category1Services: any[] = [];
  let category2Services: any[] = [];
  let category1Title: string = 'Services';
  let category2Title: string = '';

  // First check if the serviceDetails has head_categories from the API (dynamic data)
  if (serviceDetails && (serviceDetails as any).head_categories && (serviceDetails as any).head_categories.length > 0) {
    // Use the head_categories from the API response (dynamic data)
    const headCategories = (serviceDetails as any).head_categories || [];

    if (headCategories.length >= 2) {
      // Take the first 2 head categories as the main categories to display
      const headCat1 = headCategories[0];
      const headCat2 = headCategories[1];

      // Get sub-categories for each head category
      let rawCategory1Services = headCat1.sub_categories || headCat1.sub_services || [];
      let rawCategory2Services = headCat2.sub_categories || headCat2.sub_services || [];

      // Limit to 3 subcategories each
      rawCategory1Services = rawCategory1Services.slice(0, 3);
      rawCategory2Services = rawCategory2Services.slice(0, 3);

      // Map the API service data to preserve original names, images, and descriptions based on service type
      category1Services = rawCategory1Services.map((service: any, index: number) => {
        // Preserve the real service ID for pricing but use appropriate display names
        let displayName = service.name;
        let displayDescription = service.description || service.detailedDescription;
        let displayIcon = service.icon;
        let displayCategory = service.category;

        // For car washing, map to specific names based on API service name
        if (serviceSlug === 'car-washing') {
          // Map services based on their names (as received from API) to exact mock data names
          if ((headCat1.name.toLowerCase().includes('interior') || headCat1.slug?.toLowerCase().includes('interior')) ||
              (service.name.toLowerCase().includes('interior'))) {
            // Map interior services based on keywords in the name
            if (service.name.toLowerCase().includes('basic interior') || service.name.toLowerCase().includes('basic') && service.name.toLowerCase().includes('interior')) {
              displayName = 'Interior Basic Clean';
              displayDescription = 'Basic interior cleaning including vacuuming seats and carpets, wiping down dashboard and surfaces, cleaning windows, and removing surface debris. Perfect for regular maintenance between deep cleans.';
