                      if (displayName.toLowerCase().includes('interior basic') || displayName.toLowerCase().includes('basic interior')) {
                        serviceImage = "/images/services/interior-basic-service.jpg";
                      } else if (displayName.toLowerCase().includes('interior vacuum') || displayName.toLowerCase().includes('premium interior')) {
                        serviceImage = "/images/services/interior-vacuum-service.jpg";
                      } else if (displayName.toLowerCase().includes('interior detail') || displayName.toLowerCase().includes('full interior detail')) {
                        serviceImage = "/images/services/interior-detail-service.jpg";
                      } else if (displayName.toLowerCase().includes('exterior basic') || displayName.toLowerCase().includes('basic wash')) {
                        serviceImage = "/images/services/exterior-basic-service.jpg";
                      } else if (displayName.toLowerCase().includes('wax') || displayName.toLowerCase().includes('wax & polish') || displayName.toLowerCase().includes('premium wash')) {
                        serviceImage = "/images/services/exterior-wax-service.jpg";
                      } else if (displayName.toLowerCase().includes('exterior detail') || displayName.toLowerCase().includes('full exterior detail') || displayName.toLowerCase().includes('full detail')) {
                        serviceImage = "/images/services/exterior-detail-service.jpg";
                      } else if (displayName.toLowerCase().includes('exterior')) {
                        // General exterior fallback
                        serviceImage = "/images/services/exterior-service.jpg";
                      } else if (displayName.toLowerCase().includes('vacuum')) {
                        serviceImage = "/images/services/vacuum-service.jpg";
                      } else if (displayName.toLowerCase().includes('scrubbing detail')) {
                        serviceImage = "/images/services/scrubbing-detail-service.jpg";
                      } else if (displayName.toLowerCase().includes('detail') && !displayName.toLowerCase().includes('exterior') && !displayName.toLowerCase().includes('interior')) {
                        serviceImage = "/images/services/detailing-service.jpg";
                      } else if (displayName.toLowerCase().includes('wash') && !displayName.toLowerCase().includes('exterior') && !displayName.toLowerCase().includes('waterless')) {
                        serviceImage = "/images/services/wash-service.jpg";
                      } else if (displayName.toLowerCase().includes('kitchen')) {
                        serviceImage = "/images/services/kitchen-service.jpg";
                      } else if (displayName.toLowerCase().includes('bathroom')) {
                        serviceImage = "/images/services/bathroom-service.jpg";
                      } else if (displayName.toLowerCase().includes('floor')) {
                        serviceImage = "/images/services/floor-service.jpg";
                      } else if (displayName.toLowerCase().includes('window clean') || displayName.toLowerCase().includes('window cleaning')) {
                        serviceImage = "/images/services/window-service.jpg";
                      } else if (displayName.toLowerCase().includes('dusting')) {
                        serviceImage = "/images/services/dusting-service.jpg";
                      } else if (displayName.toLowerCase().includes('organizing')) {
                        serviceImage = "/images/services/organizing-service.jpg";
                      } else if (displayName.toLowerCase().includes('basic sanitization')) {
                        serviceImage = "/images/services/basic-sanitization-service.jpg";
                      } else if (displayName.toLowerCase().includes('disinfection')) {
                        serviceImage = "/images/services/disinfection-service.jpg";
                      } else if (displayName.toLowerCase().includes('ozone treatment')) {
                        serviceImage = "/images/services/ozone-treatment-service.jpg";
                      } else if (displayName.toLowerCase().includes('sanitiz') || displayName.toLowerCase().includes('disinfect')) {
                        serviceImage = "/images/services/sanitization-service.jpg";
                      } else if (displayName.toLowerCase().includes('scrubbing')) {
                        serviceImage = "/images/services/scrubbing-service.jpg";
                      } else if (displayName.toLowerCase().includes('polishing')) {
                        serviceImage = "/images/services/polishing-service.jpg";
                      } else if (displayName.toLowerCase().includes('steam')) {
                        serviceImage = "/images/services/steam-service.jpg";
                      } else if (displayName.toLowerCase().includes('pruning')) {
                        serviceImage = "/images/services/pruning-service.jpg";
                      } else if (displayName.toLowerCase().includes('lawn trimming')) {
                        serviceImage = "/images/services/lawn-trimming-service.jpg";
                      } else if (displayName.toLowerCase().includes('planting')) {
                        serviceImage = "/images/services/planting-service.jpg";
                      } else if (displayName.toLowerCase().includes('lawn mowing') || displayName.toLowerCase().includes('mowing')) {
                        serviceImage = "/images/services/lawn-mowing-service.jpg";
                      } else if (displayName.toLowerCase().includes('weeding')) {
                        serviceImage = "/images/services/weeding-service.jpg";
                      } else if (displayName.toLowerCase().includes('fertilizing')) {
                        serviceImage = "/images/services/fertilizing-service.jpg";
                      } else if (displayName.toLowerCase().includes('interior')) {
                        serviceImage = "/images/services/interior-service.jpg";
                      }
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>

        {/* Simple pricing display and confirmation */}
        <div className="border-t pt-6">
          <div className="flex justify-between items-center mb-6">
            <span className="text-lg font-semibold text-gray-900">Subtotal:</span>
            <span className="text-2xl font-bold text-teal-600">${subtotal.toFixed(2)}</span>
          </div>

          <button
            onClick={handleConfirmSelections}
            disabled={services.filter(s => (s as any).isSelected).length === 0}
            className={`w-full py-3 px-6 rounded-md text-white font-semibold ${
              services.filter(s => (s as any).isSelected).length === 0
                ? 'bg-gray-400 cursor-not-allowed'
                : 'bg-teal-600 hover:bg-teal-700'
